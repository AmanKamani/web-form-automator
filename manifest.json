{
  "manifest_version": 3,
  "name": "Web Form Automator",
  "version": "1.0.0",
  "description": "Config-driven automation for web forms — fill fields, click buttons, handle dialogs.",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_title": "Open Web Form Automator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/dialog-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
